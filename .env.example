# ==============================================================================
# CONFIGURATION RSS VEILLE
# Copiez ce fichier vers .env et modifiez les valeurs
# ==============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change_this_to_a_long_random_string_in_production
APP_URL=https://votre-domaine.com
TIMEZONE=Europe/Paris

# ─── Base de données (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_DB=rssveille
POSTGRES_USER=rssuser
POSTGRES_PASSWORD=change_this_db_password

# ─── Cache & Queue (Redis) ────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password

# ─── Intelligence Artificielle (LLM) ──────────────────────────────────────────
# Provider : "openai" ou "ollama"
LLM_PROVIDER=openai

# Configuration OpenAI (si LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-votre-cle-api-openai
OPENAI_MODEL=gpt-4o-mini

# Configuration Ollama (si LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1

# ─── Envoi d'emails ───────────────────────────────────────────────────────────
# Provider : "smtp" ou "sendgrid"
EMAIL_PROVIDER=smtp

# Configuration SMTP (si EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=votre-email@gmail.com
SMTP_PASSWORD=votre-mot-de-passe-d-application
MAIL_FROM=noreply@votre-domaine.com

# Configuration SendGrid (si EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=SG.votre-cle-api-sendgrid
# MAIL_FROM=noreply@votre-domaine.com

# ─── Planification (Heures locales selon TIMEZONE) ────────────────────────────
# Heure de collecte des flux RSS (ex: 6h00)
RSS_FETCH_HOUR=6
RSS_FETCH_MINUTE=0

# Heure de génération et envoi des synthèses quotidiennes (ex: 7h00)
DAILY_SYNTHESIS_HOUR=7
DAILY_SYNTHESIS_MINUTE=0

# Jour et heure de génération des synthèses hebdomadaires (ex: lundi 8h00)
WEEKLY_SYNTHESIS_DAY=monday
WEEKLY_SYNTHESIS_HOUR=8

# Heure de vérification de santé quotidienne (après génération 7h + envoi 7h30)
HEALTH_CHECK_HOUR=10
HEALTH_CHECK_MINUTE=0

# ─── Alertes et supervision ───────────────────────────────────────────────────
# Email de l'administrateur qui recevra les rapports de santé et alertes
ADMIN_EMAIL=admin@votre-domaine.com

# Envoyer le rapport de santé même quand tout est OK (false = seulement si anomalie)
HEALTH_CHECK_ALWAYS_REPORT=false

# ─── Limites LLM ──────────────────────────────────────────────────────────────
# Taille maximale du prompt en caractères avant troncature automatique
# 1 token ≈ 4 caractères. gpt-5-nano = 200k TPM → réduire à 200000 si nécessaire
LLM_MAX_PROMPT_CHARS=400000

# ─── Enrichissement full-text des articles ─────────────────────────────────────────
# Seuil en caractères sous lequel un article est considéré "pauvre" et sera enrichi
ARTICLE_MIN_CONTENT_LENGTH=500

# Timeout HTTP pour la visite de chaque article (secondes)
ARTICLE_ENRICH_TIMEOUT=15

# Délai minimum entre 2 requêtes vers le même domaine (secondes)
# Augmenter si certains sites bloquent les requêtes trop rapides
ARTICLE_ENRICH_RATE_LIMIT=2

# Nombre de threads parallèles pour l'enrichissement
# Réduire si la charge CPU/réseau est trop importante
ARTICLE_ENRICH_MAX_WORKERS=5

# N'enrichit que les articles publiés ou collectés dans les N derniers jours
ARTICLE_ENRICH_MAX_AGE_DAYS=7

# User-Agent utilisé pour visiter les pages des articles
# Par défaut : Firefox standard (discret et légal)
# Exemples :
#   Firefox Linux  : Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0
#   Chrome Windows : Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
#   Safari macOS   : Mozilla/5.0 (Macintosh; Intel Mac OS X 14_4) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.4 Safari/605.1.15
ARTICLE_ENRICH_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64; rv:128.0) Gecko/20100101 Firefox/128.0

# ─── Limites et Rétention ─────────────────────────────────────────────────────
MAX_FEEDS_PER_USER=100
MAX_CATEGORIES_PER_USER=20
ARTICLES_RETENTION_DAYS=90
LOG_LEVEL=INFO
