# ==============================================================================
# CONFIGURATION RSS VEILLE
# Copiez ce fichier vers .env et modifiez les valeurs
# ==============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change_this_to_a_long_random_string_in_production
APP_URL=https://votre-domaine.com
TIMEZONE=Europe/Paris

# ─── Base de données (PostgreSQL) ─────────────────────────────────────────────
POSTGRES_DB=rssveille
POSTGRES_USER=rssuser
POSTGRES_PASSWORD=change_this_db_password

# ─── Cache & Queue (Redis) ────────────────────────────────────────────────────
REDIS_PASSWORD=change_this_redis_password

# ─── Intelligence Artificielle (LLM) ──────────────────────────────────────────
# Provider : "openai" ou "ollama"
LLM_PROVIDER=openai

# Configuration OpenAI (si LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-votre-cle-api-openai
OPENAI_MODEL=gpt-4o-mini

# Configuration Ollama (si LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.1

# ─── Envoi d'emails ───────────────────────────────────────────────────────────
# Provider : "smtp" ou "sendgrid"
EMAIL_PROVIDER=smtp

# Configuration SMTP (si EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=votre-email@gmail.com
SMTP_PASSWORD=votre-mot-de-passe-d-application
MAIL_FROM=noreply@votre-domaine.com

# Configuration SendGrid (si EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=SG.votre-cle-api-sendgrid
# MAIL_FROM=noreply@votre-domaine.com

# ─── Planification (Heures locales selon TIMEZONE) ────────────────────────────
# Heure de collecte des flux RSS (ex: 6h00)
RSS_FETCH_HOUR=6
RSS_FETCH_MINUTE=0

# Heure de génération et envoi des synthèses quotidiennes (ex: 7h00)
DAILY_SYNTHESIS_HOUR=7
DAILY_SYNTHESIS_MINUTE=0

# Jour et heure de génération des synthèses hebdomadaires (ex: lundi 8h00)
WEEKLY_SYNTHESIS_DAY=monday
WEEKLY_SYNTHESIS_HOUR=8

# ─── Limites et Rétention ─────────────────────────────────────────────────────
MAX_FEEDS_PER_USER=100
MAX_CATEGORIES_PER_USER=20
ARTICLES_RETENTION_DAYS=90
LOG_LEVEL=INFO
